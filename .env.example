# The Boardwalk — Firebase config.
#
# SETUP: copy this file to `.env.local` and fill it from the Firebase console at
#   Project settings -> Your apps -> Web app -> SDK setup and configuration.
# `.env.local` is gitignored. `npm run build` FAILS if any of these are missing, so a
# site that cannot sign anyone in never reaches Pages.
#
# DEPLOY: the same five names are GitHub Actions secrets. See .github/workflows/deploy.yml.
#
# IS THIS SECRET? No — and it is worth being precise, because the answer changes what you
# should worry about. A Firebase web config is readable in the built bundle by anyone who
# opens devtools, and it has to be: the browser needs it to make its first request. Google
# documents it as non-secret. `database.rules.json` is what stops a stranger reading your
# data. What injecting it buys is that dev and prod can point at different projects, and
# that the value has ONE home instead of a copy per environment — which is the v1 row this
# rule was bought by: the config was pasted inline into 32 HTML files, each free to drift.
#
# The project is `boardwalk-fca02` (see .firebaserc, which is the rules-deploy target and
# must name the same project as VITE_FIREBASE_PROJECT_ID below).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=boardwalk-fca02.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=boardwalk-fca02
VITE_FIREBASE_APP_ID=

# Optional — analytics only, and this app has none. Leave it blank.
VITE_FIREBASE_MEASUREMENT_ID=

# The Boardwalk backend (boardwalk-api) — BACKEND_PLAN.md Phase A "shadow mode".
#
# OPTIONAL, and that is deliberate: unlike the Firebase keys above, a missing value does NOT fail
# the build. It just disables shadow mode — the app runs pure-Firebase exactly as it always has.
# So a fresh clone and the emulator harness need nothing here.
#
# When set, the composition root (src/system/repo/index.ts) keeps Firebase as the source of truth
# and ALSO mirrors every profile write to this URL, logging any read-back disagreement. Nothing
# user-visible ships; the deliverable is an empty shadow diff before Phase B trusts the server.
#
# Value = the referee's public HTTPS base (Tailscale Funnel on the Pi), no trailing path.
# DEPLOY: set the same name as a GitHub Actions secret — see .github/workflows/deploy.yml.
VITE_API_BASE_URL=

# Phase C cutover (BACKEND_PLAN.md): rooms + chat run over the boardwalk-api WebSocket referee (the
# same VITE_API_BASE_URL, over wss:// at /rooms) BY DEFAULT whenever VITE_API_BASE_URL is set. This
# var is now the KILL SWITCH: set to 0 to force rooms back onto Firebase RTDB (rebuild, no code
# change) if the Pi is down. Inert under the emulator.
VITE_WS_ROOMS=
