// THE ENFORCEMENT BOUNDARY. Not the client. Not `isDev`. This file.
//
// Ported from The Game Shack v1 (../Game-Room/database.rules.json). ARCHITECTURE.md:
// v1's security posture is the most mature thing in it and was paid for with two
// shipped backdoors — carry it over unchanged. Read
// plans/ARCHITECTURE.md#what-casino-os-v1-got-right before changing a line here.
//
// (Yes, comments in a .json file. Firebase's rules parser takes them, and rules
// without reasoning attached is how the reasoning gets lost. It is in .prettierignore
// for the same reason the docs are.)
//
// TWO DELIBERATE DEPARTURES FROM v1, both argued in ARCHITECTURE.md#phase-2:
//
//   1. v1's `chat`, `global_chat` and `$room` rules are NOT here. All three are
//      world-writable (`".write": true`), and they would be guarding nodes this app
//      does not have yet. A permissive rule for a node nothing writes is not
//      neutral — it is an open door with nothing behind it. They land in Phase 5,
//      WITH rooms and chat, and they get tightened on the way in. This is the same
//      principle eslint.config.mjs already follows: a rule lands in the phase that
//      creates its subject.
//
//   2. `usernames` is pinned to its exact field set. v1 pins `leaderboard` this way
//      and not this node. CLAUDE.md already says to `.validate` the exact field set
//      on public projections, and `usernames` is one — pinning it is what turns "real
//      emails never enter the public index" from a convention into a guarantee.
//
// DEPLOY: `npm run rules:deploy`. NOTHING IN CI DOES THIS — see the honest gap noted
// in ARCHITECTURE.md#phase-2. A rules file that does not match production is worse
// than no rules file, because it reads like the truth.
{
  "rules": {
    // Deny by default, at the root. Every node below is an explicit exception, so a
    // node nobody wrote a rule for is closed rather than open. This pair is what
    // makes departure #1 above safe rather than merely tidy.
    ".read": false,
    ".write": false,

    "users": {
      // The private record. NOT world-readable — which is exactly why `leaderboard`
      // has to exist below as a separate, rule-validated projection.
      //
      // Self or admin. `admins/<uid>` existing is the ONLY thing in this entire file
      // that grants cross-user access.
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",

        "profile": {
          // Validated even though it is private: `bankrollCents` is the economy, and
          // a write that puts a string there breaks every read of it forever.
          //
          // Money is INTEGER CENTS (CLAUDE.md — v1's `parseInt` in setMoney silently
          // ate the fractional chip on blackjack's 3:2 natural). `isNumber()` cannot
          // say "integer", so the FIELD NAME carries the unit and the client rounds.
          // Money is client-authoritative here exactly as it was in v1; the repo
          // boundary is what keeps BACKEND_PLAN.md's server-authoritative version a
          // wiring change rather than a rewrite.
          "name": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
          },
          "avatar": { ".validate": "newData.isString() && newData.val().length <= 8" },
          "bankrollCents": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "xp": { ".validate": "newData.isNumber() && newData.val() >= 0" },

          // ── Phase 4: progress ──────────────────────────────────────────────────────
          // Each field below lands WITH its writer (src/system/economy, /progress, /store,
          // /rewards) and its reader, in the same commit — the standing rule. `$other: false`
          // at the end of `profile` is what made adding them a rules change on purpose: before
          // this block, a write carrying `stats` was refused by the server, loudly.

          // Per-game play record, keyed by gameId. Counts are whole and non-negative
          // (isNumber can't say "integer"; the client rounds, like bankrollCents). `$other:
          // false` inside a game's record pins it to these four counters — a stray field is
          // refused, so `stats` cannot quietly grow a fifth key the leaderboard then leaks.
          "stats": {
            "$gameId": {
              "played": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "won": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "lost": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "pushed": { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "$other": { ".validate": false }
            }
          },

          // Unlocked achievements: id -> epoch-ms unlock time. A timestamp, not a boolean,
          // so "when" survives. Any id is allowed (the catalogue is client-side and grows),
          // but the VALUE must be a number — a badge stored as a string is a malformed record.
          "achievements": {
            "$achId": { ".validate": "newData.isNumber() && newData.val() >= 0" }
          },

          // Owned cosmetics, as a set: id -> true. The value must be exactly `true` — a set
          // membership, never `false` (which would be a not-owned flag masquerading as owned)
          // and never a richer object. Ids are client-side (the catalogue), so they are open.
          "inventory": {
            "$itemId": { ".validate": "newData.isBoolean() && newData.val() == true" }
          },

          // The daily-reward clock. Two whole non-negative numbers and nothing else — a UTC day
          // index and a streak. `$other: false` refuses anything the server does not expect,
          // which matters here because this is the field a "give me free money" edit would aim
          // at, and the shape is the only thing standing between a claim and a forged one.
          // (Money is still client-authoritative in v2 — the rules bound the SHAPE, not the
          // amount. BACKEND_PLAN.md is where the amount becomes server-authoritative.)
          "daily": {
            "lastClaimDay": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "streak": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "$other": { ".validate": false }
          },

          // NO `level` field. It is DERIVED from `xp` (see src/system/profile/xp.ts),
          // never stored — so `$other: false` below now REFUSES a write that includes
          // one, which is what keeps "level is a function, not a fact" true at the
          // server rather than only in the client.
          //
          // NOTE there is also deliberately no `isDev` field to validate. v2 does not
          // store one. See `admins` below.
          "$other": { ".validate": false }
        }
      }
    },

    "usernames": {
      // The public username -> uid index. World-readable BY DESIGN: sign-in has to
      // resolve a username to an account before anyone is authenticated.
      //
      // `viaEmail` IS A BOOLEAN AND NEVER AN EMAIL. That is the entire mechanism
      // keeping real addresses out of a world-readable node — a reader learns WHICH
      // sign-in mode an account uses, never the address. The `$other` line is what
      // makes that a rule instead of a habit.
      ".read": true,
      "$username": {
        // Claim-then-verify, from v1: writable if you already own it, or if it does
        // not exist and you are claiming it for yourself. No transaction, on purpose.
        // The REAL race-proof uniqueness is Firebase Auth rejecting a duplicate
        // synthetic address with `auth/email-already-in-use` — this index is a lookup
        // table, not the lock. See src/system/auth/credentials.ts.
        ".write": "auth != null && (data.child('uid').val() === auth.uid || (!data.exists() && newData.child('uid').val() === auth.uid) || root.child('admins').child(auth.uid).exists())",
        // The key shape is pinned too: the public index cannot be polluted with junk
        // keys, and it agrees with USERNAME_RE in src/system/auth/credentials.ts.
        ".validate": "!newData.exists() || (newData.hasChildren(['uid', 'viaEmail']) && $username.matches(/^[a-z0-9_]{2,16}$/))",
        "uid": { ".validate": "newData.isString()" },
        "viaEmail": { ".validate": "newData.isBoolean()" },
        "$other": { ".validate": false }
      }
    },

    "leaderboard": {
      // The public projection of a private record. It exists because `users/` is not
      // readable, and it is the only place profile data is world-readable.
      //
      // `$other: false` is the load-bearing line. It pins the projection to exactly
      // these four fields, so a field added to the private profile later CANNOT be
      // leaked here by a writer who forgot this node is public. A fifth field is a
      // rules change, on purpose. Phase 4 adds `wins` here, with its writer, in the
      // same commit.
      ".read": true,
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".validate": "!newData.exists() || newData.hasChildren(['name'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
        },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 8" },
        "bankrollCents": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "xp": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        // Phase 4's projected field, added HERE with its writer — the `wins` the Phase 2
        // comment promised would land in the same commit as the stat it ranks. It is a
        // DERIVED sum (totalWins over the private per-game stats), projected as one number so
        // the board can rank without reading `users/`. A sixth field beyond this set is still
        // refused by `$other` below — the projection grew by exactly one, on purpose.
        "wins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        // No `level` here either — it is derived, not projected. See users/$uid/profile.
        "$other": { ".validate": false }
      }
    },

    "admins": {
      // THE ACTUAL PRIVILEGE BOUNDARY — and the reason `profile.isDev` does not exist
      // in v2 at all.
      //
      // Read-only, self-only: you may ask whether YOU are an admin; you may not
      // enumerate the list. There is no `.write` rule at any depth, so no client can
      // ever grant it. Membership is set from the Firebase console and nowhere else.
      //
      // v1 shipped TWO backdoors against this exact surface — a hardcoded
      // username+password granting `isDev` in public client source, and a second,
      // console-reachable `authenticateDev()` in system_profile.js. Both worked
      // because a client-side boolean was treated as authority. Here, the client's
      // answer to "am I an admin" is a cache with no consumer that matters: admin
      // actions attempt the write and let these rules judge it. The server is the
      // only judge.
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },

    "rooms": {
      // DEPARTURE #1 FROM PHASE 2, NOW LANDED. Phase 2 deliberately left v1's room/chat rules out
      // ("a permissive rule for a node nothing writes is an open door with nothing behind it") and
      // promised they would arrive in Phase 5, WITH rooms and chat, tightened on the way in. This
      // is that. It is strictly MORE closed than v1, whose room nodes were world-readable AND
      // world-writable: here a room is readable only by a SIGNED-IN user, and every write is
      // scoped.
      //
      // `rooms/<gameId>/<roomId>` — see src/system/repo/firebase/roomRepo.ts for the wire layout.
      "$gameId": {
        "$roomId": {
          // Readable by any signed-in user — you must be able to read a room to join it. NOT
          // world-readable (v1 was), so a signed-out stranger cannot enumerate tables. The
          // per-seat private read below is tighter still.
          ".read": "auth != null",

          // ROOM-LEVEL WRITE IS DELETE-ONLY, and that restriction is load-bearing. RTDB write
          // rules CASCADE: a write to any descendant is granted if an ANCESTOR grants it. So a
          // broad `.write` here would let the host write every seat, every presence marker, and
          // every private hand, turning the tight child rules below into dead letters. Requiring
          // `!newData.exists()` means this authorises exactly ONE thing — the host (or an admin)
          // REMOVING an emptied room — and grants nothing for any write that leaves data behind.
          // CREATE and every field write are authorised by the child rules, never by this.
          ".write": "auth != null && !newData.exists() && (data.child('meta').child('host').val() === auth.uid || root.child('admins').child(auth.uid).exists())",

          "meta": {
            // Create and status changes are authorised HERE (room-level write is delete-only). On
            // create the writer must name themselves host; thereafter only the host, or an admin.
            ".write": "auth != null && ((!data.exists() && newData.child('host').val() === auth.uid) || data.child('host').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
            "host": { ".validate": "newData.isString()" },
            "status": {
              ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'finished')"
            },
            "createdAt": { ".validate": "newData.isNumber()" },
            // No `seq` here — it lives under `state` so it can move atomically with the state it
            // orders (see roomRepo's header). A `seq` written into meta is a stray field.
            "$other": { ".validate": false }
          },

          "seats": {
            "$seatIndex": {
              // Claim-then-verify, plus host AI management. You may write a seat that is NOT
              // currently a human (claim an open/ai chair), OR one you already own (leave/change
              // yours), OR any seat if you are the host (fill/clear AI). This is what stops one
              // player evicting another — a rule v1 lacked, where any client could overwrite any
              // seat.
              ".write": "auth != null && (data.child('kind').val() !== 'human' || data.child('uid').val() === auth.uid || root.child('rooms').child($gameId).child($roomId).child('meta').child('host').val() === auth.uid)",
              ".validate": "newData.hasChildren(['kind'])",
              "kind": {
                ".validate": "newData.val() === 'open' || newData.val() === 'human' || newData.val() === 'ai'"
              },
              "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
              // A uid, when written, MUST be the writer's own — you cannot seat someone else in a
              // human chair. AI/open seats carry no uid, so this validator simply does not run for
              // them.
              "uid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
              "$other": { ".validate": false }
            }
          },

          "state": {
            // Any participant may advance the shared state — the economy-style client-authoritative
            // posture (BACKEND_PLAN.md arbitrates later). The ordering guarantee is not left to the
            // client, though:
            ".write": "auth != null",
            "seq": {
              // MONOTONIC, ENFORCED AT THE SERVER. A write that does not strictly increase seq is
              // refused — so UNO's clock-skew bug (a stale write clobbering a newer one) cannot
              // happen even if a client tries. `!data.exists()` allows the first write.
              ".validate": "newData.isNumber() && (!data.exists() || newData.val() > data.val())"
            }
            // `data` (the game's TPublic) is intentionally unvalidated — its shape is the game's.
          },

          // HIDDEN INFORMATION IS NOT HERE — it is the top-level `hands` node below. It CANNOT
          // live under this room, because `.read: auth != null` above cascades to every descendant
          // and READ cascade cannot be revoked deeper: a child `.read` can only ADD access, never
          // remove it. A private node under a signed-in-readable room would be readable by every
          // signed-in user, which is the exact opposite of its purpose. So it lives in a sibling
          // subtree with no permissive ancestor, where its owner-only read actually holds.

          "presence": {
            // Self-only, and always the value `true` — presence is a set membership, not data. The
            // server clears it via onDisconnect (a delete, which skips this validator).
            "$uid": {
              ".write": "auth != null && $uid === auth.uid",
              ".validate": "newData.isBoolean() && newData.val() === true"
            }
          }
        }
      }
    },

    "hands": {
      // HIDDEN INFORMATION — the half of v1's privacy design v1's rules could not express. v1's UNO
      // wrote hands to a separate node so a bystander was never SENT opponents' cards; a determined
      // one could still READ the node (BACKEND_PLAN.md: "the data layout is privacy, not security").
      // Here the read is a RULE: only the account sitting in the seat may read its hand. It is a
      // TOP-LEVEL node, deliberately not under `rooms/`, because a room is signed-in-readable and
      // read access cascades down un-revokably — see the note where `private` used to be.
      //
      // `hands/<gameId>/<roomId>/<seatIndex>` — mirrors the room path so a hand maps to its seat.
      "$gameId": {
        "$roomId": {
          "$seatIndex": {
            // Read ONLY by the account in that seat — resolved against the room's seat array.
            ".read": "auth != null && root.child('rooms').child($gameId).child($roomId).child('seats').child($seatIndex).child('uid').val() === auth.uid",
            // Written by the seat's owner OR the host — the dealer deals each player their hand.
            ".write": "auth != null && (root.child('rooms').child($gameId).child($roomId).child('seats').child($seatIndex).child('uid').val() === auth.uid || root.child('rooms').child($gameId).child($roomId).child('meta').child('host').val() === auth.uid)"
          }
        }
      }
    },

    "chat": {
      // The other half of departure #1. v1's `chat`/`global_chat` were `".write": true` — anyone
      // could write anything, including a forged author. Here a signed-in user reads a room's
      // chat, and a message's `uid` is PINNED to the sender: the exact fix for v1's bug, where
      // chat trusted a client-asserted identity (and the dev badge riding alongside it).
      "$gameId": {
        "$roomId": {
          ".read": "auth != null",
          // Room-level write is the host's: it authorises `clear` (removing the whole node). A
          // non-host never writes here directly — they write a single message below, whose own
          // rule grants it.
          ".write": "auth != null && root.child('rooms').child($gameId).child($roomId).child('meta').child('host').val() === auth.uid",
          "$msgId": {
            // An author may write their own message. (Host deletion is covered by the room-level
            // write above.)
            ".write": "auth != null && newData.child('uid').val() === auth.uid",
            ".validate": "newData.hasChildren(['uid', 'name', 'text', 'key'])",
            // THE PIN. The author cannot be forged.
            "uid": { ".validate": "newData.val() === auth.uid" },
            "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40" },
            "text": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500" },
            "key": { ".validate": "newData.isString()" },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
