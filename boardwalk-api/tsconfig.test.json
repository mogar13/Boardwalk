{
  // Typecheck-only config: the build's options, widened to cover tests. vitest runs the tests
  // (esbuild strips types without checking them), so this is what actually type-checks them —
  // and what VSCode uses when a tests/ file is open, since only this config includes them.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "."
  },
  // `vitest.config.ts` is in here so it is typechecked AND lintable. It is the file that decides
  // which tests run at all; leaving it out of every program is how a config quietly stops matching
  // the tests it is supposed to collect.
  "include": ["src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
