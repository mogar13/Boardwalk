{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  // The BUILD config: only src, rootDir src → `dist/server.js`, no tests shipped.
  // Tests are typechecked by tsconfig.test.json and run by vitest.
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
